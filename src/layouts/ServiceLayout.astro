---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import Breadcrumbs from '~/components/Breadcrumbs.astro';
import TrustBar from '~/components/TrustBar.astro';
import ProcessSteps from '~/components/ProcessSteps.astro';
import FAQ from '~/components/FAQ.astro';
import CTABanner from '~/components/CTABanner.astro';
import AreaGrid from '~/components/AreaGrid.astro';
import ProjectGallery from '~/components/ProjectGallery.astro';
import { serviceSchema, breadcrumbSchema, faqSchema } from '~/lib/schema';
import type { Service } from '~/data/services';
import { business } from '~/data/business';

interface Props { service: Service; }
const { service } = Astro.props as Props;
const path = `/services/${service.slug}/`;

const crumbs = [
  { name: 'Home', href: '/' },
  { name: 'Services', href: '/services/' },
  { name: service.shortName, href: path },
];

const schemas = [
  serviceSchema(service),
  breadcrumbSchema(crumbs),
  faqSchema(service.faqs),
];

const title = `${service.metaTitleBase} | Inland Empire`;
const description = service.metaDescBase;

// Build a wider project gallery: combine service-specific photos with a curated set.
const galleryPool: { src: string; alt: string }[] = [
  ...(service.gallery ?? []),
  { src: '/images/hardwood-modern-open-living.webp', alt: 'Wide-plank hardwood in a modern open-concept living space' },
  { src: '/images/hardwood-formal-living-room.webp', alt: 'Hardwood flooring in a formal Inland Empire living room' },
  { src: '/images/hardwood-large-living-space.webp', alt: 'Hardwood flooring across a large open living space' },
  { src: '/images/hardwood-kitchen-flooring.webp', alt: 'Hardwood kitchen flooring installation' },
  { src: '/images/hardwood-staircase-installation.webp', alt: 'Hardwood staircase installation' },
  { src: '/images/luxury-vinyl-plank-living-room.webp', alt: 'Luxury vinyl plank flooring in a living room' },
  { src: '/images/luxury-vinyl-plank-styled-room.webp', alt: 'Styled room with luxury vinyl plank flooring' },
  { src: '/images/laminate-large-space.webp', alt: 'Laminate flooring across a large room' },
  { src: '/images/monteros-flooring-team-installation.webp', alt: 'Monteros crew installing hardwood flooring' },
];
const seen = new Set<string>();
const projectPhotos = galleryPool.filter((p) => p.src !== service.heroImage && !seen.has(p.src) && seen.add(p.src)).slice(0, 8);
---
<BaseLayout
  title={title}
  description={description}
  pathname={path}
  image={service.heroImage}
  schemas={schemas}
>
  <Hero
    eyebrow={`Inland Empire ${service.shortName}`}
    title={service.name}
    subtitle={service.oneLiner}
    image={service.heroImage}
    alt={service.altText}
  />

  <TrustBar />

  <section class="container-wide pt-12 pb-6">
    <div class="mb-4"><Breadcrumbs items={crumbs} /></div>
    <div class="max-w-3xl">
      <h2 class="text-balance">{service.name} Across the Inland Empire</h2>
      <p class="mt-5 text-lg md:text-xl text-slate-700 leading-relaxed">{service.oneLiner}</p>
      <p class="mt-4 text-lg text-slate-700 leading-relaxed">For {business.yearsInBusiness}+ years, {business.brandName} has been the family-owned flooring crew Inland Empire homeowners call when they want it done right the first time. Every job comes with a written, itemized estimate, on-time crews, daily clean-up, and a lifetime workmanship guarantee.</p>
    </div>
  </section>

  {(() => {
    const photos = (service.gallery ?? []).filter((g) => g.src !== service.heroImage);
    type Block = { heading: string; body: any };
    const blocks: Block[] = [
      {
        heading: `What's Included`,
        body: (
          <ul class="space-y-3 text-lg text-slate-700">
            {service.benefits.map((b) => (
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-2 w-2 rounded-full bg-brand-500 shrink-0"></span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        ),
      },
      {
        heading: 'How a Project Starts',
        body: (
          <p class="text-lg text-slate-700 leading-relaxed">Every {service.shortName.toLowerCase()} project starts the same way - a free, in-home walk-through where we measure, talk through species and finish, and answer every question you have. No rushed quotes, no high-pressure sales script. The estimate you sign is the price you pay.</p>
        ),
      },
      ...(service.materials && service.materials.length > 0 ? [{
        heading: 'Materials We Carry',
        body: (
          <ul class="grid sm:grid-cols-2 gap-x-6 gap-y-3 text-lg text-slate-700">
            {service.materials!.map((m) => (
              <li class="flex items-start gap-3">
                <span class="mt-1.5 h-2 w-2 rounded-full bg-brand-500 shrink-0"></span>
                <span>{m}</span>
              </li>
            ))}
          </ul>
        ),
      }] : []),
      {
        heading: 'Why Inland Empire Homes Choose Us',
        body: (
          <p class="text-lg text-slate-700 leading-relaxed">Hot, dry summers and cool, damp winters chew through cheaply installed floors. We acclimate every board on-site, moisture-test the subfloor, and choose the right adhesive or fastener pattern for the climate - the kind of detail that separates a floor that lasts decades from one that cups, gaps, or peaks in two summers.</p>
        ),
      },
      {
        heading: 'The Same Crew, Every Time',
        body: (
          <p class="text-lg text-slate-700 leading-relaxed">Whether you're matching a 1950's parquet, fitting wide-plank European oak, or putting waterproof LVP into a busy family kitchen, the same crew shows up with the same standards. That consistency is why we still get calls from customers we worked for fifteen years ago.</p>
        ),
      },
      {
        heading: 'Built Around Your Schedule',
        body: (
          <p class="text-lg text-slate-700 leading-relaxed">We give you a real start date, a real finish date, and the crew lead's direct line. No mystery delays, no subcontractor handoffs. If something changes, you hear it from us first.</p>
        ),
      },
    ];

    return blocks.map((b, i) => {
      const photo = photos[i];
      const reverse = i % 2 === 1;
      const altBg = i % 2 === 1 ? 'bg-brand-50/40' : '';
      if (!photo) {
        return (
          <section class={`${altBg}`}>
            <div class="container-wide py-12 md:py-16">
              <div class="max-w-3xl">
                <h3 class="text-2xl md:text-3xl font-bold text-brand-900" data-reveal>{b.heading}</h3>
                <div class="mt-5" data-reveal data-reveal-delay="100">{b.body}</div>
              </div>
            </div>
          </section>
        );
      }
      return (
        <section class={`${altBg}`}>
          <div class="container-wide py-12 md:py-16">
            <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
              <figure class={reverse ? 'lg:order-2' : ''} data-reveal={reverse ? 'left' : 'right'}>
                <img src={photo.src} alt={photo.alt} loading="lazy" decoding="async" class="w-full rounded-2xl shadow-xl ring-1 ring-brand-100" />
              </figure>
              <div class={reverse ? 'lg:order-1' : ''} data-reveal={reverse ? 'right' : 'left'} data-reveal-delay="100">
                <h3 class="text-2xl md:text-3xl font-bold text-brand-900">{b.heading}</h3>
                <div class="mt-5">{b.body}</div>
              </div>
            </div>
          </div>
        </section>
      );
    });
  })()}

  <section class="container-wide py-12">
    <div class="flex flex-wrap gap-3">
      <a href="/free-estimate/" class="btn-primary">Get a Free Estimate</a>
      <a href={`tel:${business.phoneE164}`} class="btn-secondary">Call {business.phoneDisplay}</a>
    </div>
  </section>

  <div class="bg-slate-50">
    <ProcessSteps steps={service.process} heading={`Our ${service.shortName} Process`} subheading="Every project follows the same clear, predictable steps from estimate to walk-through." />
  </div>

  <ProjectGallery
    heading={`${service.shortName} Projects Across the Inland Empire`}
    subheading={`A look at recent ${service.shortName.toLowerCase()} jobs - homes, kitchens, stairs, and more.`}
    photos={projectPhotos}
  />

  <FAQ faqs={service.faqs} heading={`${service.shortName} FAQ`} />

  <AreaGrid heading="Areas We Serve" subheading={`We bring ${service.shortName.toLowerCase()} to homes across the Inland Empire - find your city.`} />

  <CTABanner />
</BaseLayout>
