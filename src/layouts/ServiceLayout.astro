---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import Breadcrumbs from '~/components/Breadcrumbs.astro';
import TrustBar from '~/components/TrustBar.astro';
import ProcessSteps from '~/components/ProcessSteps.astro';
import FAQ from '~/components/FAQ.astro';
import CTABanner from '~/components/CTABanner.astro';
import AreaGrid from '~/components/AreaGrid.astro';
import { serviceSchema, breadcrumbSchema, faqSchema } from '~/lib/schema';
import type { Service } from '~/data/services';
import { business } from '~/data/business';
import { priceRange } from '~/lib/formatting';

interface Props { service: Service; }
const { service } = Astro.props as Props;
const path = `/services/${service.slug}/`;

const crumbs = [
  { name: 'Home', href: '/' },
  { name: 'Services', href: '/services/' },
  { name: service.shortName, href: path },
];

const schemas = [
  serviceSchema(service),
  breadcrumbSchema(crumbs),
  faqSchema(service.faqs),
];

const title = `${service.metaTitleBase} | Inland Empire`;
const description = service.metaDescBase;
---
<BaseLayout
  title={title}
  description={description}
  pathname={path}
  image={service.heroImage}
  schemas={schemas}
>
  <Hero
    eyebrow={`Inland Empire ${service.shortName}`}
    title={service.name}
    subtitle={service.oneLiner}
    image={service.heroImage}
    alt={service.altText}
  />

  <TrustBar />

  <section class="container-wide py-16">
    <div class="mb-4"><Breadcrumbs items={crumbs} /></div>

    <div class="grid lg:grid-cols-3 gap-10 items-start">
      <div class="lg:col-span-2 prose-brand">
        <h2>{service.name} Across the Inland Empire</h2>
        <p>{service.oneLiner}</p>
        <p>For {business.yearsInBusiness}+ years, {business.brandName} has been the family-owned flooring crew Inland Empire homeowners call when they want it done right the first time. Every job comes with a written, itemized estimate, on-time crews, daily clean-up, and a lifetime workmanship guarantee.</p>

        <h3>What's Included</h3>
        <ul>
          {service.benefits.map((b) => <li>{b}</li>)}
        </ul>

        {service.materials && service.materials.length > 0 && (
          <>
            <h3>Materials We Carry</h3>
            <ul>{service.materials.map((m) => <li>{m}</li>)}</ul>
          </>
        )}
      </div>

      <aside class="card p-6 lg:sticky lg:top-24">
        <div class="text-xs uppercase tracking-wider text-brand-700 font-semibold">Project Snapshot</div>
        <div class="mt-3 space-y-3 text-sm">
          <div class="flex justify-between"><span class="text-slate-600">Pricing</span><span class="font-semibold">{priceRange(service.priceFromUSD, service.priceToUSD, service.intent === 'repair' ? '/repair' : '/sq ft')}</span></div>
          <div class="flex justify-between"><span class="text-slate-600">Timeline</span><span class="font-semibold text-right">{service.timeline}</span></div>
          <div class="flex justify-between"><span class="text-slate-600">Estimate</span><span class="font-semibold">Free, in-home</span></div>
          <div class="flex justify-between"><span class="text-slate-600">Warranty</span><span class="font-semibold">Lifetime workmanship</span></div>
        </div>
        <a href="/contact/" class="btn-primary w-full mt-5">Get a Free Estimate</a>
        <a href={`tel:${business.phoneE164}`} class="btn-secondary w-full mt-2">Call {business.phoneDisplay}</a>
      </aside>
    </div>
  </section>

  <div class="bg-slate-50">
    <ProcessSteps steps={service.process} heading={`Our ${service.shortName} Process`} subheading="Every project follows the same clear, predictable steps from estimate to walk-through." />
  </div>

  <FAQ faqs={service.faqs} heading={`${service.shortName} FAQ`} />

  <AreaGrid heading="Areas We Serve" subheading={`We bring ${service.shortName.toLowerCase()} to homes across the Inland Empire - find your city.`} />

  <CTABanner />
</BaseLayout>
