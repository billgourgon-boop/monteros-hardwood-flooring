---
import { business } from '~/data/business';
import { services } from '~/data/services';
import { cities } from '~/data/cities';
---

<footer class="bg-brand-950 text-slate-300 mt-24">
  <div class="container-wide py-14">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-10">
      <div>
        <div class="flex items-center gap-3 mb-3">
          <img src={business.brand.logo} alt="" width="40" height="40" loading="lazy" decoding="async" class="h-10 w-10 rounded-md bg-white p-1" />
          <div class="leading-tight">
            <div class="font-display text-lg font-bold text-white">{business.shortName}</div>
            <div class="text-[11px] uppercase tracking-wider text-brand-300 font-semibold">Hardwood Flooring</div>
          </div>
        </div>
        <p class="text-sm leading-relaxed">{business.tagline}. Family-owned for {business.yearsInBusiness}+ years across {business.serviceArea.primaryCounty} and the Inland Empire.</p>
        <div class="mt-4 space-y-2 text-sm">
          <a href={`tel:${business.phoneE164}`} class="flex items-center gap-2 text-white hover:text-brand-200">
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M2 4a2 2 0 012-2h2.5a1 1 0 01.97.757l1.5 6a1 1 0 01-.504 1.125l-1.85.925a11 11 0 005.585 5.585l.925-1.85a1 1 0 011.125-.504l6 1.5A1 1 0 0118 16.5V19a2 2 0 01-2 2h-1C7.611 21 1 14.389 1 6V5a2 2 0 011-1z"/></svg>
            {business.phoneDisplay}
          </a>
          <a href={`mailto:${business.email}`} class="flex items-center gap-2 hover:text-white">
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/></svg>
            {business.email}
          </a>
          <address class="not-italic text-sm flex items-start gap-2 mt-2">
            <svg class="h-4 w-4 mt-0.5 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
            <span>{business.address.street}<br/>{business.address.city}, {business.address.region} {business.address.postalCode}</span>
          </address>
        </div>
      </div>

      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Services</h4>
        <ul class="space-y-2 text-sm">
          {services.map((s) => (
            <li><a href={`/services/${s.slug}/`} class="hover:text-white">{s.shortName}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Areas We Serve</h4>
        <ul class="space-y-2 text-sm">
          {cities.slice(0, 8).map((c) => (
            <li><a href={`/areas-we-serve/${c.slug}/`} class="hover:text-white">{c.name}, {c.state}</a></li>
          ))}
          <li><a href="/areas-we-serve/" class="text-brand-200 hover:text-white font-semibold">View all cities →</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Company</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/about/" class="hover:text-white">About Monteros</a></li>
          <li><a href="/process/" class="hover:text-white">Our Process</a></li>
          <li><a href="/reviews/" class="hover:text-white">Reviews</a></li>
          <li><a href="/financing/" class="hover:text-white">Financing</a></li>
          <li><a href="/warranty/" class="hover:text-white">Warranty</a></li>
          <li><a href="/faq/" class="hover:text-white">FAQ</a></li>
          <li><a href="/blog/" class="hover:text-white">Blog</a></li>
          <li><a href="https://monteros.localfloorpros.com/book-now-page" class="hover:text-white">Contact</a></li>
          <li><a href="/sitemap/" class="hover:text-white">Sitemap</a></li>
        </ul>
        <div class="mt-5 flex flex-wrap items-center gap-2">
          {business.social.facebook && (
            <a href={business.social.facebook} aria-label="Facebook" target="_blank" rel="noopener" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/5 hover:bg-[#1877F2] hover:scale-110 transition-all duration-200">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12a10 10 0 10-11.6 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.3c-1.2 0-1.6.8-1.6 1.6V12h2.7l-.4 2.9h-2.3v7A10 10 0 0022 12z"/></svg>
            </a>
          )}
          {business.social.instagram && (
            <a href={business.social.instagram} aria-label="Instagram" target="_blank" rel="noopener" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/5 hover:bg-gradient-to-tr hover:from-[#F58529] hover:via-[#DD2A7B] hover:to-[#8134AF] hover:scale-110 transition-all duration-200">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.2c3.2 0 3.6 0 4.8.1 1.2.1 1.9.3 2.3.4.6.2 1 .5 1.4.9.4.4.7.8.9 1.4.2.5.4 1.1.4 2.3.1 1.3.1 1.6.1 4.8s0 3.6-.1 4.8c-.1 1.2-.3 1.9-.4 2.3-.2.6-.5 1-.9 1.4-.4.4-.8.7-1.4.9-.5.2-1.1.4-2.3.4-1.3.1-1.6.1-4.8.1s-3.6 0-4.8-.1c-1.2-.1-1.9-.3-2.3-.4a3.9 3.9 0 01-1.4-.9 3.9 3.9 0 01-.9-1.4c-.2-.5-.4-1.1-.4-2.3-.1-1.3-.1-1.6-.1-4.8s0-3.6.1-4.8c.1-1.2.3-1.9.4-2.3.2-.6.5-1 .9-1.4.4-.4.8-.7 1.4-.9.5-.2 1.1-.4 2.3-.4 1.3-.1 1.6-.1 4.8-.1zm0 6.5a3.3 3.3 0 100 6.6 3.3 3.3 0 000-6.6zm0 5.4a2.1 2.1 0 110-4.2 2.1 2.1 0 010 4.2zM17 6.6a.8.8 0 100 1.6.8.8 0 000-1.6z"/></svg>
            </a>
          )}
          {business.social.google && (
            <a href={business.social.google} aria-label="Google Reviews" target="_blank" rel="noopener" class="flex h-10 w-10 items-center justify-center rounded-full bg-white hover:scale-110 transition-all duration-200">
              <svg class="h-5 w-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.5 12.27c0-.79-.07-1.54-.2-2.27H12v4.51h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.32z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A10.99 10.99 0 0012 23z"/><path fill="#FBBC05" d="M5.84 14.1c-.22-.66-.35-1.36-.35-2.1s.13-1.44.35-2.1V7.07H2.18A10.99 10.99 0 001 12c0 1.77.42 3.45 1.18 4.93l3.66-2.83z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.83C6.71 7.31 9.14 5.38 12 5.38z"/></svg>
            </a>
          )}
          {business.social.yelp && (
            <a href={business.social.yelp} aria-label="Yelp" target="_blank" rel="noopener" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/5 hover:bg-[#D32323] hover:scale-110 transition-all duration-200">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.16 12.6l-4.26-1.39c-.62-.2-1.16.18-1.16.84v4.36c0 .66.54 1.06 1.16.86l4.26-1.39c.62-.2.74-.92.27-1.39l-1.04-1.04 1.04-1.04c.47-.47.35-1.61-.27-1.81zm-7.42 4.9l-1.39 4.26c-.2.62.18 1.16.84 1.16h.18c.66 0 1.06-.54.86-1.16l-1.39-4.26c-.2-.62-.92-.74-1.39-.27.47.47.59.92.29 1.27zm.93-2.32l4.34-1.41c.62-.2.74-.92.27-1.39L15.3 9.4c-.47-.47-1.18-.35-1.39.27l-1.41 4.34c-.2.62.18 1.16.84 1.16h.32zm-3.49-2.97V3.4c0-.66-.46-1.04-1.05-.83-1.83.65-3.5 1.62-4.92 2.86-.5.43-.43 1.18.13 1.45l4.79 2.34c.62.29 1.05-.04 1.05-.61zm-1.09 4.71L4.46 14.5c-.62-.2-1.27.27-1.16.92.32 1.78 1.04 3.4 2.07 4.79.39.51 1.13.43 1.41-.16l2.41-4.79c.32-.62-.04-1.32-.7-1.34z"/></svg>
            </a>
          )}
          {business.social.angi && (
            <a href={business.social.angi} aria-label="Angi" target="_blank" rel="noopener" class="flex h-10 px-3 items-center justify-center rounded-full bg-white/5 hover:bg-[#FF6153] hover:scale-110 transition-all duration-200 font-extrabold text-sm tracking-tight">
              Angi
            </a>
          )}
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col md:flex-row md:items-center md:justify-between gap-4 text-xs text-slate-400">
      <div>© {new Date().getFullYear()} {business.legalName}. Family-owned for {business.yearsInBusiness}+ years. CSLB licensed and insured.</div>
      <div class="flex items-center gap-4">
        <a href="/privacy/" class="hover:text-white">Privacy</a>
        <a href="/terms/" class="hover:text-white">Terms</a>
        <a href="/sitemap.xml" class="hover:text-white">XML Sitemap</a>
      </div>
    </div>
  </div>
</footer>
