---
import { business } from '~/data/business';
interface Props { title?: string; subtitle?: string; }
const {
  title = 'Ready to upgrade your floors?',
  subtitle = `Free in-home estimate. Honest pricing. ${business.yearsInBusiness}+ years of Inland Empire craftsmanship.`,
} = Astro.props as Props;
---
<section class="relative bg-gradient-to-br from-brand-800 via-brand-700 to-brand-900 text-white overflow-hidden">
  <div class="absolute -top-20 -left-20 h-72 w-72 rounded-full bg-brand-400/20 blur-3xl drift" aria-hidden="true"></div>
  <div class="absolute -bottom-20 -right-20 h-80 w-80 rounded-full bg-brand-300/20 blur-3xl drift" style="animation-delay:-3s" aria-hidden="true"></div>
  <div class="relative container-wide py-14 md:py-20 text-center">
    <h2 class="text-white text-balance" data-reveal>{title}</h2>
    <p class="mt-4 text-lg text-brand-100 max-w-2xl mx-auto text-balance" data-reveal data-reveal-delay="100">{subtitle}</p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3" data-reveal data-reveal-delay="200">
      <a href="https://monteros.localfloorpros.com/book-now-page" class="btn-cta">Get a Free Estimate</a>
      <a href={`tel:${business.phoneE164}`} class="btn-outline">Call {business.phoneDisplay}</a>
    </div>
  </div>
</section>
