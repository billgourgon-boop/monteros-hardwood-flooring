---
import { business } from '~/data/business';
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  image: string;
  alt: string;
  primaryCta?: { href: string; label: string };
  secondaryCta?: { href: string; label: string };
  ratingBadge?: boolean;
}
const {
  eyebrow,
  title,
  subtitle,
  image,
  alt,
  primaryCta = { href: '/free-estimate/', label: 'Get a Free Estimate' },
  secondaryCta = { href: `tel:${business.phoneE164}`, label: `Call ${business.phoneDisplay}` },
  ratingBadge = true,
} = Astro.props as Props;
---
<section class="relative overflow-hidden bg-brand-950 text-white">
  <div class="absolute inset-0 z-0">
    <img src={image} alt={alt} class="hero-kenburns h-full w-full object-cover opacity-60" loading="eager" decoding="async" fetchpriority="high" />
    <div class="absolute inset-0 bg-gradient-to-br from-brand-950/85 via-brand-900/55 to-brand-700/30"></div>
    <div class="absolute -top-24 -right-24 h-72 w-72 rounded-full bg-brand-400/20 blur-3xl drift" aria-hidden="true"></div>
    <div class="absolute -bottom-24 -left-16 h-80 w-80 rounded-full bg-brand-300/15 blur-3xl drift" style="animation-delay:-3s" aria-hidden="true"></div>
  </div>
  <div class="relative z-10 container-wide py-20 md:py-28 lg:py-32">
    <div class="max-w-2xl">
      {eyebrow && <div class="text-brand-300 font-semibold text-sm uppercase tracking-widest mb-3" data-reveal>{eyebrow}</div>}
      <h1 class="text-white text-balance" data-reveal data-reveal-delay="100">{title}</h1>
      {subtitle && <p class="mt-5 text-lg md:text-xl text-slate-100 leading-relaxed text-balance" data-reveal data-reveal-delay="200">{subtitle}</p>}
      <div class="mt-8 flex flex-wrap gap-3" data-reveal data-reveal-delay="300">
        <a href={primaryCta.href} class="btn-cta">{primaryCta.label}</a>
        <a href={secondaryCta.href} class="btn-outline">{secondaryCta.label}</a>
      </div>
      {ratingBadge && (
        <div class="mt-8 flex items-center gap-3 text-sm" data-reveal data-reveal-delay="400">
          <div class="flex items-center gap-1 text-amber-400 drop-shadow">
            {[1,2,3,4,5].map(() => (<svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path d="M10 1l2.928 6.063L19.5 8 14.75 12.625 16 19l-6-3.5L4 19l1.25-6.375L.5 8l6.572-.937L10 1z"/></svg>))}
          </div>
          <span class="text-slate-100">{business.ratings.averageRating} from {business.ratings.reviewCount}+ Inland Empire homeowners</span>
        </div>
      )}
    </div>
  </div>
  <div class="pointer-events-none absolute bottom-6 left-1/2 -translate-x-1/2 z-10 text-brand-200/70 hidden md:flex flex-col items-center gap-1 text-[10px] uppercase tracking-[0.3em]" aria-hidden="true">
    <span>Scroll</span>
    <svg class="h-4 w-4 drift" viewBox="0 0 20 20" fill="currentColor"><path d="M10 14l-5-5h10l-5 5z"/></svg>
  </div>
</section>
