---
interface Photo { src: string; alt: string; }
interface Props {
  heading?: string;
  subheading?: string;
  photos: Photo[];
}
const { heading = 'Recent Projects', subheading, photos } = Astro.props as Props;
---
{photos.length > 0 && (
  <section class="bg-white">
    <div class="container-wide py-12 md:py-16">
      <div class="max-w-3xl mx-auto text-center mb-8 md:mb-10">
        <h2 class="font-display text-2xl md:text-3xl font-extrabold text-brand-900">{heading}</h2>
        {subheading && <p class="mt-3 text-slate-600">{subheading}</p>}
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4">
        {photos.map((p, i) => (
          <figure class="overflow-hidden rounded-xl ring-1 ring-brand-100 shadow-sm group" data-reveal data-reveal-delay={String((i % 4) * 60)}>
            <img
              src={p.src}
              alt={p.alt}
              loading="lazy"
              decoding="async"
              class="w-full h-44 md:h-56 object-cover transition-transform duration-500 group-hover:scale-[1.04]"
            />
          </figure>
        ))}
      </div>
    </div>
  </section>
)}
