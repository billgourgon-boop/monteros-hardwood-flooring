---
interface FAQItem { q: string; a: string; }
interface Props { faqs: FAQItem[]; heading?: string; }
const { faqs, heading = 'Frequently Asked Questions' } = Astro.props as Props;
---
<section class="container-narrow py-16">
  <h2 class="text-balance mb-8" data-reveal>{heading}</h2>
  <dl class="divide-y divide-slate-200 border-y border-slate-200">
    {faqs.map((f, i) => (
      <details class="group py-4" open={i === 0} data-reveal data-reveal-delay={String(Math.min(i * 60, 400))}>
        <summary class="flex items-center justify-between gap-4 cursor-pointer text-left text-lg font-semibold text-brand-900 list-none hover:text-brand-700 transition-colors">
          <span>{f.q}</span>
          <span class="shrink-0 flex items-center justify-center h-7 w-7 rounded-full bg-brand-50 text-brand-700 transition-all duration-300 group-open:rotate-45 group-open:bg-brand-500 group-open:text-white text-xl leading-none">+</span>
        </summary>
        <dd class="mt-3 text-slate-700 leading-relaxed">{f.a}</dd>
      </details>
    ))}
  </dl>
</section>
