---
import { business } from '~/data/business';
---
<section class="border-y border-slate-200 bg-gradient-to-r from-brand-50 via-white to-brand-50">
  <div class="container-wide py-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
      <div data-reveal data-reveal-delay="100">
        <div class="text-3xl md:text-4xl font-display font-bold text-brand-700">
          <span data-counter={business.yearsInBusiness} data-counter-suffix="+">0+</span>
        </div>
        <div class="text-xs uppercase tracking-wider text-slate-600 mt-1">Years In Business</div>
      </div>
      <div data-reveal data-reveal-delay="200">
        <div class="text-3xl md:text-4xl font-display font-bold text-brand-700 inline-flex items-baseline gap-1">
          <span data-counter={business.ratings.averageRating}>0</span>
          <span class="text-amber-400">★</span>
        </div>
        <div class="text-xs uppercase tracking-wider text-slate-600 mt-1"><span data-counter={business.ratings.reviewCount} data-counter-suffix="+">0+</span> Reviews</div>
      </div>
      <div data-reveal data-reveal-delay="300">
        <div class="text-3xl md:text-4xl font-display font-bold text-brand-700">Lifetime</div>
        <div class="text-xs uppercase tracking-wider text-slate-600 mt-1">Workmanship Guarantee</div>
      </div>
      <div data-reveal data-reveal-delay="400">
        <div class="text-3xl md:text-4xl font-display font-bold text-brand-700">Free</div>
        <div class="text-xs uppercase tracking-wider text-slate-600 mt-1">In-Home Estimate</div>
      </div>
    </div>
  </div>
</section>
