---
import { business } from '~/data/business';
import { testimonials } from '~/data/testimonials';
const realReviews = testimonials.filter((t) => !/placeholder/i.test(t.text));
const showCards = realReviews.length > 0;
---
<section class="bg-white border-y border-brand-100">
  <div class="container-wide py-12 md:py-16">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-8" data-reveal>
      <div>
        <div class="inline-flex items-center gap-2 text-sm font-semibold text-slate-700">
          <svg class="h-5 w-5" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="#4285F4" d="M22.5 12.27c0-.79-.07-1.54-.2-2.27H12v4.51h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.32z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A10.99 10.99 0 0012 23z"/>
            <path fill="#FBBC05" d="M5.84 14.1c-.22-.66-.35-1.36-.35-2.1s.13-1.44.35-2.1V7.07H2.18A10.99 10.99 0 001 12c0 1.77.42 3.45 1.18 4.93l3.66-2.83z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.83C6.71 7.31 9.14 5.38 12 5.38z"/>
          </svg>
          Google Reviews
        </div>
        <h2 class="mt-2">What Inland Empire Homeowners Say</h2>
      </div>
      <div class="flex items-center gap-4">
        <div class="text-right">
          <div class="font-display text-3xl font-extrabold text-brand-800 leading-none">{business.ratings.averageRating}<span class="text-amber-400 ml-1">★</span></div>
          <div class="text-xs uppercase tracking-wider text-slate-600 mt-1">{business.ratings.reviewCount}+ reviews</div>
        </div>
        {business.social.google && (
          <a href={business.social.google} target="_blank" rel="noopener" class="btn-primary">Read all on Google</a>
        )}
      </div>
    </div>

    {showCards ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {realReviews.slice(0, 6).map((t, i) => (
          <article class="card p-6 flex flex-col" data-reveal data-reveal-delay={String((i % 3) * 100 + 100)}>
            <div class="flex items-center gap-1 text-amber-400 mb-3" aria-label={`${t.rating} out of 5 stars`}>
              {Array.from({ length: t.rating }).map(() => (
                <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M10 1l2.928 6.063L19.5 8 14.75 12.625 16 19l-6-3.5L4 19l1.25-6.375L.5 8l6.572-.937L10 1z"/></svg>
              ))}
            </div>
            <p class="text-slate-700 leading-relaxed flex-1">"{t.text}"</p>
            <div class="mt-4 pt-4 border-t border-slate-100 flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-100 text-brand-700 font-bold">{t.author.charAt(0)}</div>
              <div>
                <div class="font-semibold text-brand-900 text-sm">{t.author}</div>
                <div class="text-xs text-slate-500">{t.city}{t.service ? ` · ${t.service}` : ''}</div>
              </div>
              <svg class="ml-auto h-5 w-5" viewBox="0 0 24 24" aria-hidden="true">
                <path fill="#4285F4" d="M22.5 12.27c0-.79-.07-1.54-.2-2.27H12v4.51h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.32z"/>
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A10.99 10.99 0 0012 23z"/>
                <path fill="#FBBC05" d="M5.84 14.1c-.22-.66-.35-1.36-.35-2.1s.13-1.44.35-2.1V7.07H2.18A10.99 10.99 0 001 12c0 1.77.42 3.45 1.18 4.93l3.66-2.83z"/>
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.83C6.71 7.31 9.14 5.38 12 5.38z"/>
              </svg>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <a href={business.social.google} target="_blank" rel="noopener" class="block card p-6 md:p-8 text-center hover:bg-brand-50 transition-colors" data-reveal>
        <div class="flex items-center justify-center gap-1 text-amber-400 mb-3">
          {[1,2,3,4,5].map(() => (
            <svg class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor"><path d="M10 1l2.928 6.063L19.5 8 14.75 12.625 16 19l-6-3.5L4 19l1.25-6.375L.5 8l6.572-.937L10 1z"/></svg>
          ))}
        </div>
        <p class="text-lg text-slate-700 max-w-2xl mx-auto">
          Trusted by <span class="font-bold text-brand-800">{business.ratings.reviewCount}+</span> Inland Empire homeowners with a <span class="font-bold text-brand-800">{business.ratings.averageRating}-star</span> average rating on Google.
        </p>
        <span class="mt-4 inline-flex items-center gap-2 text-brand-700 font-semibold">
          Read every review on Google
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M5 10h10m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/></svg>
        </span>
      </a>
    )}
  </div>
</section>
