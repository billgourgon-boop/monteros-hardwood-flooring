---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import ServiceGrid from '~/components/ServiceGrid.astro';
import TrustBar from '~/components/TrustBar.astro';
import CTABanner from '~/components/CTABanner.astro';
import Breadcrumbs from '~/components/Breadcrumbs.astro';
import { breadcrumbSchema, faqSchema } from '~/lib/schema';
import FAQ from '~/components/FAQ.astro';
import { generalFaqs } from '~/data/faqs';

const crumbs = [
  { name: 'Home', href: '/' },
  { name: 'Services', href: '/services/' },
];
const schemas = [breadcrumbSchema(crumbs), faqSchema(generalFaqs)];
---
<BaseLayout
  title="Our Flooring Services"
  description="Hardwood installation, hardwood refinishing, luxury vinyl plank, laminate, floor repair, and stair work - across the Inland Empire. Free in-home estimates."
  pathname="/services/"
  schemas={schemas}
>
  <Hero
    eyebrow="Services"
    title="Every Floor We Install, Refinish, and Repair"
    subtitle="Six core services covering hardwood, luxury vinyl, laminate, and stair work. Family-owned craftsmanship, written quotes, and a lifetime workmanship guarantee."
    image="/images/hardwood-flooring-installation.webp"
    alt="Range of flooring options installed by Monteros across the Inland Empire"
  />
  <TrustBar />
  <section class="container-wide pt-10"><Breadcrumbs items={crumbs} /></section>
  <ServiceGrid />
  <FAQ faqs={generalFaqs} />
  <CTABanner />
</BaseLayout>
