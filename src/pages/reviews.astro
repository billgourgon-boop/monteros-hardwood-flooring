---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import TrustBar from '~/components/TrustBar.astro';
import CTABanner from '~/components/CTABanner.astro';
import Breadcrumbs from '~/components/Breadcrumbs.astro';
import { breadcrumbSchema, faqSchema } from '~/lib/schema';
import FAQ from '~/components/FAQ.astro';
import { generalFaqs } from '~/data/faqs';
import { business } from '~/data/business';
const crumbs = [{ name: 'Home', href: '/' }, { name: 'Reviews', href: '/reviews/' }];
const schemas = [breadcrumbSchema(crumbs), faqSchema(generalFaqs)];
---
<BaseLayout
  title={`Reviews | ${business.brandName} (${business.ratings.averageRating}★)`}
  description={`Customer reviews of ${business.brandName}. ${business.ratings.averageRating}-star average across ${business.ratings.reviewCount}+ Inland Empire homeowners.`}
  pathname="/reviews/"
  schemas={schemas}
>
  <Hero
    eyebrow="Reviews"
    title={`${business.ratings.averageRating}★ from ${business.ratings.reviewCount}+ Inland Empire Homeowners`}
    subtitle={`Real feedback from real ${business.serviceArea.primaryCounty} homeowners we\'ve worked with.`}
    image="/images/hardwood-flooring-installation.webp"
    alt="Customer reviews"
    ratingBadge={false}
  />
  <TrustBar />

  <section class="container-wide py-16">
    <div class="mb-4"><Breadcrumbs items={crumbs} /></div>

    <div class="grid lg:grid-cols-3 gap-10 items-start">
      <div class="lg:col-span-2 prose-brand">
        <h2>Where to Read Verified Reviews</h2>
        <p>We earn our reputation one floor at a time. The most credible places to read real reviews are third-party platforms where the reviewer is verified:</p>
        <ul>
          {business.social.google && <li><strong>Google Business Profile:</strong> <a href={business.social.google} rel="noopener">View on Google</a></li>}
          {business.social.yelp && <li><strong>Yelp:</strong> <a href={business.social.yelp} rel="noopener">View on Yelp</a></li>}
          <li><strong>Facebook:</strong> <a href={business.social.facebook} rel="noopener">View our Facebook page</a></li>
          <li><strong>Better Business Bureau (BBB):</strong> Look up "{business.brandName}" in San Bernardino, CA.</li>
        </ul>

        <p class="text-sm text-slate-500 italic">Reviews shown on this page are pulled from verified third-party platforms. We never write our own.</p>

        <h2>Why Customers Choose Us</h2>
        <ul>
          <li><strong>Honest pricing.</strong> Written, itemized quote with no add-on surprises.</li>
          <li><strong>On-time crews.</strong> When we say we\'ll be there, we\'re there.</li>
          <li><strong>Clean job sites.</strong> Drop cloths, dust containment, daily clean-up.</li>
          <li><strong>Real warranty.</strong> Lifetime workmanship guarantee in writing.</li>
          <li><strong>Family-owned.</strong> The same family bids the job and runs the install.</li>
        </ul>

        <h2>Leave a Review</h2>
        <p>If we did right by you, the kindest thing you can do is leave a review on Google or Yelp. It helps your neighbors find us - and it keeps us accountable.</p>
      </div>

      <aside class="card p-6 bg-brand-50/50 border-brand-200 lg:sticky lg:top-24">
        <div class="text-xs uppercase tracking-wider text-brand-700 font-semibold">Rating Snapshot</div>
        <div class="mt-3 text-5xl font-display font-bold text-brand-900">{business.ratings.averageRating}★</div>
        <div class="mt-1 text-sm text-slate-600">{business.ratings.reviewCount}+ reviews across platforms</div>
        <div class="mt-5 text-sm space-y-2">
          <div>★★★★★ Hardwood Installation</div>
          <div>★★★★★ Refinishing</div>
          <div>★★★★★ LVP Installation</div>
          <div>★★★★★ Repair Work</div>
        </div>
        <a href="/free-estimate/" class="btn-primary w-full mt-5">Get a Free Estimate</a>
      </aside>
    </div>
  </section>

  <FAQ faqs={generalFaqs} />
  <CTABanner />
</BaseLayout>
