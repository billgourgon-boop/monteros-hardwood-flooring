---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { business } from '~/data/business';
---
<BaseLayout
  title="Thank You - We\'ll Be in Touch"
  description="Thank you for your message. We\'ll respond within one business day."
  pathname="/thank-you/"
  noindex={true}
>
  <section class="container-narrow py-24 text-center">
    <div class="mx-auto h-16 w-16 rounded-full bg-brand-100 text-brand-700 flex items-center justify-center mb-6">
      <svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <h1>Thanks - we got it.</h1>
    <p class="mt-4 text-lg text-slate-700">We\'ll respond within one business day to schedule your free in-home estimate.</p>
    <p class="mt-2 text-slate-600">Need us sooner? Call <a href={`tel:${business.phoneE164}`} class="font-semibold">{business.phoneDisplay}</a>.</p>
    <div class="mt-10">
      <a href="/" class="btn-secondary">Back to Home</a>
    </div>
  </section>
</BaseLayout>
